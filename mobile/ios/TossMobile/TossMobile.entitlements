<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- react-native-keychain 이 Keychain 에 토큰을 저장/조회하려면 keychain-access-groups
	     entitlement 가 있어야 한다. 없으면 errSecMissingEntitlement(-34018):
	     "Internal error when a required entitlement isn't present." 가 발생. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)$(CFBundleIdentifier)</string>
	</array>
</dict>
</plist>
