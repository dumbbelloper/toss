{
  "realm": "toss",
  "enabled": true,
  "displayName": "곳간",
  "loginTheme": "gotgan",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "기본 사용자"
      },
      {
        "name": "ADMIN",
        "description": "관리자"
      }
    ]
  },
  "users": [
    {
      "username": "tester",
      "enabled": true,
      "emailVerified": true,
      "email": "tester@toss.local",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "toss-web-bff",
      "name": "Toss Web BFF (confidential)",
      "description": "웹 SPA용 BFF. 백엔드(Spring)가 secret 보유, code flow 중개.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "dev-web-bff-secret-change-me",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/login/oauth2/code/keycloak",
        "http://localhost:5173/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      }
    },
    {
      "clientId": "toss-mobile",
      "name": "Toss Mobile (React Native, public, PKCE)",
      "description": "React Native(iOS·Android 통합). secret 없음, Authorization Code + PKCE. react-native-app-auth.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "com.toss.app://oauth2redirect"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ]
}